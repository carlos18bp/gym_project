# ===========================================================================
# Environment
# ===========================================================================
DJANGO_ENV=development
DJANGO_SECRET_KEY=replace-with-strong-secret-min-50-chars
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# ===========================================================================
# Database (production uses MySQL; dev defaults to SQLite)
# ===========================================================================
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=gym_project
# DB_USER=replace
# DB_PASSWORD=replace
# DB_HOST=localhost
# DB_PORT=3306

# ===========================================================================
# Email SMTP
# ===========================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=replace
EMAIL_HOST_PASSWORD=replace
DEFAULT_FROM_EMAIL=G&M Consultores Jurídicos <replace@example.com>

# ===========================================================================
# Redis (for Huey task queue)
# ===========================================================================
REDIS_URL=redis://localhost:6379/1

# ===========================================================================
# Backups
# ===========================================================================
BACKUP_STORAGE_PATH=/var/backups/gym_project

# ===========================================================================
# Google reCAPTCHA
# ===========================================================================
RECAPTCHA_SITE_KEY=replace
RECAPTCHA_SECRET_KEY=replace

# ===========================================================================
# Google OAuth
# ===========================================================================
GOOGLE_CLIENT_ID=replace

# ===========================================================================
# Wompi Payment Gateway
# ===========================================================================
WOMPI_ENVIRONMENT=test
WOMPI_PUBLIC_KEY=replace
WOMPI_PRIVATE_KEY=replace
WOMPI_EVENTS_KEY=replace
WOMPI_INTEGRITY_KEY=replace

# ===========================================================================
# Silk profiling — set to true to enable SQL/N+1 monitoring (dev or production)
# When enabled: records HTTP requests + SQL queries to DB, runs daily GC and
# weekly slow-query report via Huey. UI dashboard at /silk/ (staff only).
# ===========================================================================
ENABLE_SILK=false

# ===========================================================================
# SECOP (Public Procurement) — datos.gov.co Socrata API
# ===========================================================================
SECOP_DATASET_ID=bt96-ncis
SECOP_APP_TOKEN=

# ===========================================================================
# Production-only: CORS / CSRF origins (comma-separated)
# ===========================================================================
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
