{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node -r ./suppress-warnings.cjs node_modules/.bin/vite",
    "build": "node -r ./suppress-warnings.cjs node_modules/.bin/vite build && node scripts/generate-django-template.cjs",
    "build:e2e": "node -r ./suppress-warnings.cjs node_modules/.bin/vite build --outDir dist --base /",
    "preview": "node -r ./suppress-warnings.cjs node_modules/.bin/vite preview",
    "test": "node -r ./suppress-warnings.cjs node_modules/.bin/jest --config jest.config.cjs",
    "test:coverage": "node -r ./suppress-warnings.cjs node_modules/.bin/jest --config jest.config.cjs --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "e2e:coverage": "npm run e2e:clean && playwright test",
    "e2e:desktop": "playwright test --project=\"Desktop Chrome\"",
    "e2e:mobile": "playwright test --project=\"Mobile Chrome\"",
    "e2e:tablet": "playwright test --project=\"Tablet\"",
    "e2e:clean": "node ./scripts/e2e-clean.cjs",
    "e2e:modules": "npm run e2e:clean && node ./scripts/e2e-modules.cjs",
    "e2e:coverage:module": "npm run e2e:clean && node ./scripts/e2e-coverage-module.cjs",
    "e2e:module": "npm run e2e:clean && node ./scripts/e2e-module.cjs"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tinymce/tinymce-vue": "^6.3.0",
    "axios": "^1.16.1",
    "bootstrap-icons": "^1.13.1",
    "docx": "^9.6.1",
    "dompurify": "^3.4.4",
    "file-saver": "^2.0.5",
    "flowbite": "^2.5.2",
    "gsap": "^3.15.0",
    "headlessui": "^0.0.0",
    "heroicons": "^2.2.0",
    "pinia": "^2.3.1",
    "sweetalert2": "^11.26.24",
    "swiper": "^12.1.4",
    "tinymce": "^7.9.2",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "vue3-google-login": "^2.1.4",
    "vue3-recaptcha2": "^1.8.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4",
    "@tootallnate/once": "^3.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/parser": "^7.29.3",
    "@babel/preset-env": "^7.29.5",
    "@babel/traverse": "^7.29.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/vue3-jest": "^29.2.6",
    "autoprefixer": "^10.5.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-istanbul": "^6.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.10.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-transform-stub": "^2.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0"
  }
}
