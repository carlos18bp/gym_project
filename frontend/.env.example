# ===========================================================================
# Google OAuth — must match the GOOGLE_CLIENT_ID in backend/.env
# ===========================================================================
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id

# ===========================================================================
# Microsoft Entra (Azure AD) OAuth — must match MICROSOFT_CLIENT_ID in backend/.env
# Application (Client) ID from the Azure App Registration. The redirect URI
# ${VITE_APP_DOMAIN}/auth/outlook/callback must be registered as a "SPA"
# platform, and ID tokens must be enabled in the app's Authentication settings.
# ===========================================================================
VITE_MICROSOFT_CLIENT_ID=replace-with-azure-client-id

# ===========================================================================
# Application domain (used for Google + Microsoft OAuth redirect_uri)
# ===========================================================================
VITE_APP_DOMAIN=http://localhost:5173

# ===========================================================================
# TinyMCE Cloud API key — get yours at https://www.tiny.cloud/
# Add the deploy domains to the Approved Domains list in the tiny.cloud dashboard
# ===========================================================================
VITE_TINYMCE_API_KEY=replace-with-tinymce-api-key
