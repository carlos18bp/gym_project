# ===========================================================================
# Google OAuth — must match the GOOGLE_CLIENT_ID in backend/.env
# ===========================================================================
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id

# ===========================================================================
# Application domain (used for Google OAuth redirect_uri)
# ===========================================================================
VITE_APP_DOMAIN=http://localhost:5173

# ===========================================================================
# TinyMCE Cloud API key — get yours at https://www.tiny.cloud/
# Add the deploy domains to the Approved Domains list in the tiny.cloud dashboard
# ===========================================================================
VITE_TINYMCE_API_KEY=replace-with-tinymce-api-key
