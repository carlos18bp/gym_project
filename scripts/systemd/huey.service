[Unit]
Description=Huey Task Queue for gym_project
After=network.target redis.service

[Service]
Type=simple
User=ryzepeck
Group=www-data
WorkingDirectory=/home/ryzepeck/webapps/gym_project/backend
EnvironmentFile=/home/ryzepeck/webapps/gym_project/backend/.env
ExecStart=/home/ryzepeck/webapps/gym_project/backend/venv/bin/python manage.py run_huey
Restart=always
RestartSec=5
Environment="DJANGO_ENV=production"

[Install]
WantedBy=multi-user.target
